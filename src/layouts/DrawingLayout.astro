---
import BaseLayout from './BaseLayout.astro';
import DrawingViewer from '../components/DrawingViewer.astro';
import TagPills from '../components/TagPills.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import ResilienceDriversDiagram from '../components/diagrams/ResilienceDriversDiagram.astro';

interface Props {
  drawingId: string;
  title: string;
  image: string;
  alt: string;
  scaleLevel: string;
  drawingType: string;
  display?: {
    variant?: 'default' | 'board' | 'full';
  };
  supportImages?: Array<{
    src: string;
    alt: string;
    variant?: 'board' | 'full';
  }>;
  pageLayout?: 'default' | 'split-lead';
  bodyPosition?: 'after' | 'before';
  pageIntroTitle?: string;
  pageIntroText?: string;
  relatedSections?: string[];
  tags: { topic: string[]; scale: string[]; type: string[] };
}

const {
  drawingId,
  title,
  image,
  alt,
  scaleLevel,
  drawingType,
  display = { variant: 'default' },
  supportImages = [],
  pageLayout = 'default',
  bodyPosition = 'after',
  pageIntroTitle,
  pageIntroText,
  relatedSections = [],
  tags,
} = Astro.props;

const allSections = await getCollection('sections');
const sections = allSections.filter((s) => relatedSections.includes(s.id));

const customDiagramRegistry = {
  'case-studies-map': ResilienceDriversDiagram,
} as const;

const CustomDiagram = customDiagramRegistry[drawingId as keyof typeof customDiagramRegistry];
const hasCustomDiagram = Boolean(CustomDiagram);
const inferredBoardImage = image.includes('/final_ppt_cropped/') || image.includes('/images/drawings/updated_');
const viewerVariant = display.variant && display.variant !== 'default'
  ? display.variant
  : inferredBoardImage
    ? 'board'
    : 'full';
const useSplitLead = pageLayout === 'split-lead' && bodyPosition === 'before' && !hasCustomDiagram;
---

<BaseLayout title={title} description={alt}>
  <div class="max-w-5xl mx-auto px-6 py-20" data-pagefind-body>
    <Breadcrumbs crumbs={[
      { label: 'Drawings', href: '/drawing/' },
      { label: scaleLevel, href: `/scale/${scaleLevel}` },
      { label: title },
    ]} />

    <div class="section-label">{scaleLevel} Scale - {drawingType}</div>
    <h1 class="section-title mb-4">{title}</h1>

    <TagPills topics={tags.topic} scales={tags.scale} types={tags.type} />

    {(pageIntroTitle || pageIntroText) && (
      <div class="mt-8 max-w-3xl">
        {pageIntroTitle && <div class="section-label mb-3">{pageIntroTitle}</div>}
        {pageIntroText && <p class="text-lg leading-relaxed text-text-muted my-0">{pageIntroText}</p>}
      </div>
    )}

    {useSplitLead ? (
      <div class="split-lead mt-8">
        <div class="prose split-lead-copy">
          <slot />
        </div>
        <div class="split-lead-visual">
          <DrawingViewer src={image} alt={alt} title={title} variant={viewerVariant} />
          {supportImages.length > 0 && (
            <div class="support-image-stack">
              {supportImages.map((supportImage) => (
                <DrawingViewer
                  src={supportImage.src}
                  alt={supportImage.alt}
                  title={title}
                  variant={supportImage.variant ?? 'board'}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    ) : (
      <>
        <div class:list={['mt-8', hasCustomDiagram ? 'custom-diagram-block' : '']}>
          {CustomDiagram ? (
            <CustomDiagram title={title} alt={alt} />
          ) : (
            <DrawingViewer src={image} alt={alt} title={title} variant={viewerVariant} />
          )}
        </div>

        <div class="prose mt-8">
          <slot />
        </div>

        {supportImages.length > 0 && (
          <div class="support-image-stack mt-8">
            {supportImages.map((supportImage) => (
              <DrawingViewer
                src={supportImage.src}
                alt={supportImage.alt}
                title={title}
                variant={supportImage.variant ?? 'board'}
              />
            ))}
          </div>
        )}
      </>
    )}

    {sections.length > 0 && (
      <div class="mt-12">
        <h3 class="text-[0.8rem] tracking-widest uppercase text-accent mb-4">Related Sections</h3>
        <ul class="space-y-2 list-none">
          {sections.map((s) => (
            <li>
              <a href={`/read/${s.id}`} class="text-text-muted hover:text-text no-underline transition-colors">
                {s.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .custom-diagram-block {
    margin-top: 2.5rem;
  }

  .split-lead {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .split-lead-copy {
    margin-top: 0;
  }

  .split-lead-visual {
    min-width: 0;
  }

  .support-image-stack {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 960px) {
    .split-lead {
      grid-template-columns: minmax(18rem, 24rem) minmax(0, 1fr);
      gap: 2.5rem;
    }

    .split-lead-copy {
      position: sticky;
      top: 6.5rem;
    }
  }
</style>
