---
interface Props {
  topic: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { topic, size = 'md', class: className = '' } = Astro.props;

const sizeMap = {
  sm: 'h-4',
  md: 'h-6',
  lg: 'h-12',
};

const sizeClass = sizeMap[size] || sizeMap.md;

const topics = ['water', 'fire', 'coastal', 'cultural-heritage', 'ecology', 'housing', 'infrastructure', 'mobility', 'policy', 'recovery', 'zoning'];
const hasIcon = topics.includes(topic);
const label = topic.replaceAll('-', ' ');
---

{hasIcon && (
  <img
    src={`/icons/topics/${topic}.png`}
    alt=""
    aria-hidden="true"
    class:list={[sizeClass, 'w-auto inline-block rounded-sm', className]}
    loading="lazy"
  />
)}
