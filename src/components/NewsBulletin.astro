---
---

<section class="max-w-4xl mx-auto px-6 py-16">
  <div class="flex items-baseline justify-between mb-6">
    <h2 class="font-serif text-2xl">Latest Maui & Lahaina News</h2>
    <span id="news-status" class="text-sm text-text-muted">Loading...</span>
  </div>

  <div id="news-feed" class="space-y-0 border border-border rounded overflow-hidden">
    <!-- Skeleton loading state -->
    <div class="news-skeleton">
      {Array.from({ length: 4 }).map(() => (
        <div class="p-4 border-b border-border animate-pulse">
          <div class="h-4 bg-surface rounded w-3/4 mb-2" />
          <div class="h-3 bg-surface rounded w-1/3" />
        </div>
      ))}
    </div>
  </div>

  <p class="text-xs text-text-muted mt-3">
    News sourced from Google News. Updates automatically.
  </p>
</section>

<script is:inline>
  (async function loadNews() {
    const feed = document.getElementById('news-feed');
    const status = document.getElementById('news-status');
    if (!feed || !status) return;

    try {
      // Use Netlify function in production, fallback for local dev
      const isLocal = window.location.hostname === 'localhost';
      const url = isLocal
        ? 'https://news.google.com/rss/search?q=Lahaina+Maui&hl=en-US&gl=US&ceid=US:en'
        : '/.netlify/functions/news';

      let items = [];

      if (isLocal) {
        // In local dev, show a placeholder message
        feed.innerHTML = `
          <div class="p-6 text-center text-text-muted">
            <p class="text-sm">News feed loads from Netlify in production.</p>
            <p class="text-sm mt-1">Deploy to Netlify to see live news.</p>
          </div>
        `;
        status.textContent = 'Preview mode';
        return;
      }

      const resp = await fetch(url);
      const data = await resp.json();
      items = data.items || [];

      if (items.length === 0) {
        feed.innerHTML = `
          <div class="p-6 text-center text-text-muted">
            <p class="text-sm">No recent news available right now. Check back later.</p>
          </div>
        `;
        status.textContent = '';
        return;
      }

      feed.innerHTML = items.map(function(item) {
        const date = item.date ? new Date(item.date) : null;
        const timeAgo = date ? formatTimeAgo(date) : '';

        return '<a href="' + item.link + '" target="_blank" rel="noopener noreferrer" ' +
          'class="block p-4 border-b border-border last:border-b-0 no-underline hover:bg-surface transition-colors group">' +
          '<h3 class="text-base text-text group-hover:text-accent transition-colors leading-snug mb-1">' +
            item.title +
          '</h3>' +
          '<div class="flex items-center gap-2 text-sm text-text-muted">' +
            '<span>' + item.source + '</span>' +
            (timeAgo ? '<span>&middot;</span><span>' + timeAgo + '</span>' : '') +
          '</div>' +
        '</a>';
      }).join('');

      status.textContent = 'Updated just now';

    } catch (err) {
      feed.innerHTML = '<div class="p-6 text-center text-text-muted">' +
        '<p class="text-sm">Unable to load news right now.</p></div>';
      status.textContent = '';
    }
  })();

  function formatTimeAgo(date) {
    var now = new Date();
    var diff = Math.floor((now.getTime() - date.getTime()) / 1000);
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
</script>
