---
---

<div class="bg-white border border-border rounded-lg shadow-lg overflow-hidden">
  <div class="px-5 pt-5 pb-3">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-red-500 animate-pulse" aria-hidden="true"></span>
        <h2 class="font-sans text-sm font-semibold tracking-wide uppercase text-text">Live Updates</h2>
      </div>
      <span id="news-status" class="text-xs text-text-muted">Loading...</span>
    </div>
  </div>

  <div id="news-feed" class="max-h-[300px] md:max-h-[480px] overflow-y-auto">
    <!-- Skeleton loading state -->
    <div class="news-skeleton">
      {Array.from({ length: 5 }).map(() => (
        <div class="px-5 py-3 border-t border-border animate-pulse">
          <div class="h-3.5 bg-surface rounded w-full mb-2" />
          <div class="h-3 bg-surface rounded w-1/2" />
        </div>
      ))}
    </div>
  </div>

  <div class="px-5 py-2.5 border-t border-border bg-surface">
    <p class="text-xs text-text-muted">
      Maui & Lahaina news via Google News
    </p>
  </div>
</div>

<script is:inline>
  (async function loadNews() {
    var feed = document.getElementById('news-feed');
    var status = document.getElementById('news-status');
    if (!feed || !status) return;

    try {
      var resp = await fetch('/data/news.json');
      if (!resp.ok) throw new Error('No news data');
      var data = await resp.json();
      var items = data.items || [];

      if (items.length === 0) {
        feed.replaceChildren(makeMessage(null, 'No recent news available right now. Check back later.'));
        status.textContent = '';
        return;
      }

      var frag = document.createDocumentFragment();
      items.forEach(function(item) {
        var date = item.date ? new Date(item.date) : null;
        var timeAgo = date ? formatTimeAgo(date) : '';

        var a = document.createElement('a');
        a.href = item.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'block px-5 py-3 border-t border-border no-underline hover:bg-surface transition-colors group';

        var h3 = document.createElement('h3');
        h3.className = 'text-sm text-text group-hover:text-accent transition-colors leading-snug mb-0.5';
        h3.textContent = item.title;
        a.appendChild(h3);

        var meta = document.createElement('div');
        meta.className = 'flex items-center gap-1.5 text-xs text-text-muted';
        var srcSpan = document.createElement('span');
        srcSpan.textContent = item.source;
        meta.appendChild(srcSpan);
        if (timeAgo) {
          var dot = document.createElement('span');
          dot.textContent = '\u00B7';
          meta.appendChild(dot);
          var timeSpan = document.createElement('span');
          timeSpan.textContent = timeAgo;
          meta.appendChild(timeSpan);
        }
        a.appendChild(meta);
        frag.appendChild(a);
      });
      feed.replaceChildren(frag);

      if (data.updated) {
        status.textContent = 'Updated ' + formatTimeAgo(new Date(data.updated));
      } else {
        status.textContent = '';
      }

    } catch (err) {
      feed.replaceChildren(makeMessage('News Unavailable', 'Please try refreshing the page.'));
      status.textContent = '';
    }
  })();

  function formatTimeAgo(date) {
    var now = new Date();
    var diff = Math.floor((now.getTime() - date.getTime()) / 1000);
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function makeMessage(heading, body) {
    var div = document.createElement('div');
    div.className = 'p-6 text-center text-text-muted';
    if (heading) {
      var p1 = document.createElement('p');
      p1.className = 'text-sm font-medium mb-1';
      p1.textContent = heading;
      div.appendChild(p1);
    }
    var p2 = document.createElement('p');
    p2.className = heading ? 'text-xs' : 'text-sm';
    p2.textContent = body;
    div.appendChild(p2);
    return div;
  }
</script>
