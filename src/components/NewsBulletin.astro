---
---

<div class="bg-white border border-border rounded-lg shadow-lg overflow-hidden">
  <div class="px-5 pt-5 pb-3">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-red-500 animate-pulse" aria-hidden="true"></span>
        <h2 class="font-sans text-sm font-semibold tracking-wide uppercase text-text">Live Updates</h2>
      </div>
      <span id="news-status" class="text-xs text-text-muted">Loading...</span>
    </div>
  </div>

  <div id="news-feed" class="max-h-[480px] overflow-y-auto">
    <!-- Skeleton loading state -->
    <div class="news-skeleton">
      {Array.from({ length: 5 }).map(() => (
        <div class="px-5 py-3 border-t border-border animate-pulse">
          <div class="h-3.5 bg-surface rounded w-full mb-2" />
          <div class="h-3 bg-surface rounded w-1/2" />
        </div>
      ))}
    </div>
  </div>

  <div class="px-5 py-2.5 border-t border-border bg-surface">
    <p class="text-xs text-text-muted">
      Maui & Lahaina news via Google News
    </p>
  </div>
</div>

<script is:inline>
  (async function loadNews() {
    var feed = document.getElementById('news-feed');
    var status = document.getElementById('news-status');
    if (!feed || !status) return;

    try {
      var isLocal = window.location.hostname === 'localhost';
      var url = isLocal
        ? null
        : '/.netlify/functions/news';

      if (isLocal) {
        feed.innerHTML =
          '<div class="p-6 text-center text-text-muted">' +
            '<p class="text-sm font-medium mb-1">Live News Updates</p>' +
            '<p class="text-sm">News feed activates when the site is deployed to Netlify.</p>' +
          '</div>';
        status.textContent = 'Preview mode';
        return;
      }

      var resp = await fetch(url);
      var data = await resp.json();
      var items = data.items || [];

      if (items.length === 0) {
        feed.innerHTML =
          '<div class="p-6 text-center text-text-muted">' +
            '<p class="text-sm">No recent news available right now. Check back later.</p>' +
          '</div>';
        status.textContent = '';
        return;
      }

      feed.innerHTML = items.map(function(item) {
        var date = item.date ? new Date(item.date) : null;
        var timeAgo = date ? formatTimeAgo(date) : '';

        return '<a href="' + item.link + '" target="_blank" rel="noopener noreferrer" ' +
          'class="block px-5 py-3 border-t border-border no-underline hover:bg-surface transition-colors group">' +
          '<h3 class="text-sm text-text group-hover:text-accent transition-colors leading-snug mb-0.5">' +
            item.title +
          '</h3>' +
          '<div class="flex items-center gap-1.5 text-xs text-text-muted">' +
            '<span>' + item.source + '</span>' +
            (timeAgo ? '<span>&middot;</span><span>' + timeAgo + '</span>' : '') +
          '</div>' +
        '</a>';
      }).join('');

      status.textContent = 'Updated just now';

    } catch (err) {
      feed.innerHTML =
        '<div class="p-6 text-center text-text-muted">' +
          '<p class="text-sm font-medium mb-1">News Unavailable</p>' +
          '<p class="text-xs">Please try refreshing the page.</p>' +
        '</div>';
      status.textContent = '';
    }
  })();

  function formatTimeAgo(date) {
    var now = new Date();
    var diff = Math.floor((now.getTime() - date.getTime()) / 1000);
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
</script>
