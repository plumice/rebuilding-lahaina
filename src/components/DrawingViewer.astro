---
interface Props {
  src: string;
  alt: string;
  title: string;
  variant?: 'board' | 'full';
}

const { src, alt, title, variant = 'full' } = Astro.props;
---

<figure class:list={[
  'drawing-figure',
  variant === 'board'
    ? 'mx-auto max-w-[56rem] border border-[#ddd8cf] bg-[#f7f3eb] p-3 sm:p-4'
    : 'border border-border bg-surface p-4',
]}>
  <img
    src={src}
    alt={alt}
    class:list={[
      'zoomable cursor-zoom-in',
      variant === 'board' ? 'mx-auto block h-auto max-h-[78vh] w-auto max-w-full object-contain' : 'w-full h-auto',
    ]}
    loading="lazy"
    tabindex="0"
    role="button"
    aria-label={`Press Enter to enlarge: ${title}`}
  />
</figure>

<style>
  .drawing-figure {
    margin: 0;
  }
</style>

<script>
  import mediumZoom from 'medium-zoom';
  const zoom = mediumZoom('.zoomable', {
    background: 'rgba(255, 255, 255, 0.95)',
    margin: 24,
  });
  document.querySelectorAll<HTMLImageElement>('.zoomable').forEach((img) => {
    img.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        zoom.open({ target: img });
      }
    });
  });
</script>
