---
interface Props {
  src: string;
  alt: string;
  title: string;
}

const { src, alt, title } = Astro.props;
---

<figure class="bg-surface border border-border p-4">
  <img
    src={src}
    alt={alt}
    class="w-full h-auto cursor-zoom-in zoomable"
    loading="lazy"
    tabindex="0"
    role="button"
    aria-label={`Press Enter to enlarge: ${title}`}
  />
  <figcaption class="mt-3 text-[0.8rem] text-text-muted tracking-wide">
    {title}
  </figcaption>
</figure>

<script>
  import mediumZoom from 'medium-zoom';
  const zoom = mediumZoom('.zoomable', {
    background: 'rgba(255, 255, 255, 0.95)',
    margin: 24,
  });
  document.querySelectorAll('.zoomable').forEach((img) => {
    img.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        zoom.open({ target: img });
      }
    });
  });
</script>
