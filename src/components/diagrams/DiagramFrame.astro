---
interface Props {
  title: string;
  alt: string;
}

const { title, alt } = Astro.props;
---

<figure class="bg-surface border border-border p-4">
  <div class="diagram-shell" role="img" aria-label={alt}>
    <slot />
  </div>
  <figcaption class="mt-3 text-[0.8rem] text-text-muted tracking-wide">
    {title}
  </figcaption>
</figure>

<style>
  .diagram-shell {
    width: 100%;
    overflow: hidden;
  }

  .diagram-shell :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    background: #fff;
  }
 </style>
