---
interface Props {
  title?: string;
  alt: string;
}

const { alt } = Astro.props;
---

<figure class="diagram-frame">
  <div class="diagram-shell" role="img" aria-label={alt}>
    <slot />
  </div>
</figure>

<style>
  .diagram-frame {
    margin: 0;
  }

  .diagram-shell {
    width: 100%;
    overflow: visible;
    padding-block: 1rem;
    border-top: 1px solid #ddd8cf;
    border-bottom: 1px solid #ddd8cf;
  }

  .diagram-shell :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    background: transparent;
  }
</style>
