---
import DiagramFrame from './DiagramFrame.astro';

interface Props {
  title: string;
  alt: string;
}

const { title, alt } = Astro.props;

const recoveryCases = [
  ['New Orleans (Post-Katrina, 2005)', 'X-Codes', 'Levee System Upgrades', 'Grassroots Recovery'],
  ['Kobe, Japan (1995 Earthquake)', 'Public Parks as Shelters', 'Seismic Retrofitting', 'Community Engagement'],
  ['Chile (2010 Earthquake and Tsunami)', 'Incremental Housing', 'Public-Private Collaboration', 'Rapid Housing Programs'],
  ['Peru (2007 Ica Earthquake)', 'Decentralized Aid Networks', 'Cultural Preservation', 'International Assistance'],
  ['Indonesia (2004 Tsunami)', 'Community Driven Reconstruction', 'Climate Resilient Designs', 'Cultural Sensitivity'],
  ['Bangladesh (Cyclone Sidr, 2007)', 'Local Materials for Reconstruction'],
  ['Haiti (2010 Earthquake)', 'Challenges of International Collaboration'],
];

const nodeCases = [
  ['New Orleans (Post-Katrina, 2005)', 'Community Schools', 'Cultural Anchors'],
  ['Medellin, Colombia (Library Parks Program)', 'Library Parks', 'Public Spaces'],
  ['Singapore (Park Connector Network)', 'Green Corridors', 'Sustainable Infrastructure'],
  ['Copenhagen (Superkilen Park)', 'Diverse Public Space', 'Community Interaction'],
  ['Netherlands (Room for the River Program)', 'Floodable Parks', 'Ecological Integration'],
  ['Machado & Silvetti (Valparaiso, Chile)', 'Artistic Interventions', 'Public Amenities'],
];

const driverBlocks = [
  {
    x: 542,
    y: 222,
    color: '#4f6d9c',
    title: 'Systemic Drivers',
    lines: [
      'Frameworks or actions that',
      'focus on rebuilding infra-',
      'structure, governance, and',
      'systems for future disaster',
      'preparedness.',
    ],
  },
  {
    x: 542,
    y: 360,
    color: '#75a86d',
    title: 'Community-Led Recovery',
    lines: [
      'Drivers',
      'Grassroots efforts or par-',
      'ticipatory approaches that',
      'empower local communities',
      'in the rebuilding process and',
      'collective memory.',
    ],
  },
  {
    x: 542,
    y: 536,
    color: '#b05b67',
    title: 'Cultural Resilience Drivers',
    lines: [
      'Recovery efforts centered on',
      'preserving cultural identity,',
      'collective memory, and social',
      'cohesion.',
    ],
  },
];

const nodeBlocks = [
  {
    x: 822,
    y: 214,
    color: '#4da86a',
    title: 'Functional Node',
    lines: [
      'Functional nodes are prac-',
      'tical, utility-driven spaces or',
      'systems that support daily',
      'life, improve infrastructure,',
      'and enhance disaster resil-',
      'ience.',
    ],
  },
  {
    x: 822,
    y: 406,
    color: '#b05b67',
    title: 'Cultural/Symbolic Node',
    lines: [
      'Symbolic nodes are identi-',
      'ty-driven spaces that reflect a',
      "community's culture, history,",
      'and collective memory.',
    ],
  },
];
---

<DiagramFrame title={title} alt={alt}>
  <svg viewBox="0 0 1400 760" aria-hidden="true">
    <defs>
      <marker id="rd-arrowhead" markerWidth="10" markerHeight="10" refX="8" refY="5" orient="auto">
        <path d="M0,0 L10,5 L0,10 z" fill="#c76366"></path>
      </marker>
      <marker id="rd-mini" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
        <path d="M0,0 L8,4 L0,8 z" fill="#111"></path>
      </marker>
    </defs>

    <line x1="90" y1="84" x2="1310" y2="84" stroke="#111" stroke-dasharray="2 8" stroke-width="2"></line>
    <line x1="736" y1="48" x2="736" y2="590" stroke="#111" stroke-dasharray="2 8" stroke-width="2"></line>
    <line x1="90" y1="590" x2="1310" y2="590" stroke="#111" stroke-dasharray="2 8" stroke-width="2"></line>

    <text x="390" y="52" text-anchor="middle" font-size="18" font-weight="600" fill="#333">Disaster Recovery</text>
    <text x="390" y="74" text-anchor="middle" font-size="16" fill="#555">Catalyst of Resilience Drivers</text>
    <text x="1115" y="52" text-anchor="middle" font-size="18" font-weight="600" fill="#333">Urbanism of Nodes</text>
    <text x="1115" y="74" text-anchor="middle" font-size="16" fill="#555">Catalyst of Community Anchors</text>

    {recoveryCases.map((group, index) => {
      const y = 124 + index * 74;
      return (
        <g>
          {group.map((line, lineIndex) => (
            <text x="92" y={y + lineIndex * 20} font-size="15" fill="#202020">{line}</text>
          ))}
        </g>
      );
    })}

    {nodeCases.map((group, index) => {
      const y = 124 + index * 86;
      return (
        <g>
          {group.map((line, lineIndex) => (
            <text x="1286" y={y + lineIndex * 20} text-anchor="end" font-size="15" fill="#202020">{line}</text>
          ))}
        </g>
      );
    })}

    {driverBlocks.map((block) => (
      <g>
        <circle cx={block.x - 26} cy={block.y + 26} r="3.5" fill="#111"></circle>
        <circle cx={block.x - 26} cy={block.y + 56} r="3.5" fill="#111"></circle>
        <text x={block.x} y={block.y} font-size="17" font-weight="700" fill={block.color}>{block.title}</text>
        {block.lines.map((line, index) => (
          <text x={block.x} y={block.y + 28 + index * 18} font-size="14" font-weight="600" fill={block.color}>{line}</text>
        ))}
      </g>
    ))}

    {nodeBlocks.map((block) => (
      <g>
        <circle cx={block.x - 26} cy={block.y + 24} r="3.5" fill="#111"></circle>
        <circle cx={block.x - 26} cy={block.y + 52} r="3.5" fill="#111"></circle>
        <text x={block.x} y={block.y} font-size="17" font-weight="700" fill={block.color}>{block.title}</text>
        {block.lines.map((line, index) => (
          <text x={block.x} y={block.y + 24 + index * 18} font-size="14" font-weight="600" fill={block.color}>{line}</text>
        ))}
      </g>
    ))}

    {[166, 240, 314, 388, 462].map((y) => (
      <path d={`M345 ${y} C 410 ${y - 24}, 455 ${y - 12}, 505 ${y + 8}`} fill="none" stroke="#d7d7d7" stroke-width="2.5" stroke-dasharray="7 10" marker-end="url(#rd-mini)"></path>
    ))}
    {[210, 308, 406].map((y) => (
      <path d={`M960 ${y} C 1012 ${y - 24}, 1060 ${y - 8}, 1118 ${y + 12}`} fill="none" stroke="#d7d7d7" stroke-width="2.5" stroke-dasharray="7 10" marker-end="url(#rd-mini)"></path>
    ))}

    <path d="M352 118 C 400 94, 442 100, 444 144 L 444 544 C 444 586, 470 618, 524 624" fill="none" stroke="#c76366" stroke-width="3.5" marker-end="url(#rd-arrowhead)"></path>
    <path d="M1092 258 C 1058 214, 1030 218, 1028 268 L 1028 560 C 1028 596, 1000 624, 952 634" fill="none" stroke="#c76366" stroke-width="3.5" marker-end="url(#rd-arrowhead)"></path>

    <text x="444" y="662" text-anchor="middle" font-size="16" font-weight="600" fill="#333">Lahaina's Native Hawaiian</text>
    <text x="444" y="684" text-anchor="middle" font-size="16" font-weight="600" fill="#333">heritage</text>
    <text x="1028" y="662" text-anchor="middle" font-size="16" font-weight="600" fill="#333">Lahaina's potential for integrating</text>
    <text x="1028" y="684" text-anchor="middle" font-size="16" font-weight="600" fill="#333">water sensitive spaces</text>

    <text x="640" y="710" text-anchor="middle" font-size="64" fill="#efede9" font-weight="700">Lahaina</text>
  </svg>
</DiagramFrame>
