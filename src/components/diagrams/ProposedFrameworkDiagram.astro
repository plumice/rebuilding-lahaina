---
import DiagramFrame from './DiagramFrame.astro';

interface Props {
  title: string;
  alt: string;
}

const { title, alt } = Astro.props;
---

<DiagramFrame title={title} alt={alt}>
  <svg viewBox="0 0 1400 820" aria-hidden="true">
    <defs>
      <linearGradient id="pf-blue" x1="0%" x2="100%" y1="0%" y2="0%">
        <stop offset="0%" stop-color="#4587c6"></stop>
        <stop offset="100%" stop-color="#68a6dd"></stop>
      </linearGradient>
      <linearGradient id="pf-orange" x1="0%" x2="100%" y1="0%" y2="0%">
        <stop offset="0%" stop-color="#e47d33"></stop>
        <stop offset="100%" stop-color="#f1a14e"></stop>
      </linearGradient>
      <marker id="pf-blue-arrow" markerWidth="12" markerHeight="12" refX="9" refY="6" orient="auto">
        <path d="M0,0 L12,6 L0,12 z" fill="#4b8fd2"></path>
      </marker>
      <marker id="pf-orange-arrow" markerWidth="12" markerHeight="12" refX="9" refY="6" orient="auto">
        <path d="M0,0 L12,6 L0,12 z" fill="#ec7a33"></path>
      </marker>
    </defs>

    <text x="24" y="40" font-size="13" font-style="italic" fill="#666">
      Multi-scalar framework rooted in the ahupua'a model linking coast, urban core, peri-urban buffer, and hinterland.
    </text>

    <ellipse cx="560" cy="548" rx="260" ry="170" fill="rgba(244, 219, 106, 0.55)" stroke="#e7c65d" stroke-width="2"></ellipse>
    <ellipse cx="885" cy="402" rx="280" ry="175" fill="rgba(203, 181, 138, 0.58)" stroke="#b99f6d" stroke-width="2"></ellipse>
    <ellipse cx="835" cy="510" rx="270" ry="165" fill="rgba(144, 190, 93, 0.55)" stroke="#8ca857" stroke-width="2"></ellipse>
    <ellipse cx="725" cy="432" rx="292" ry="165" fill="rgba(77, 171, 203, 0.46)" stroke="#439fbe" stroke-width="2"></ellipse>

    <ellipse cx="695" cy="477" rx="148" ry="102" fill="#e8ecec" stroke="#6a7373" stroke-width="2"></ellipse>
    <text x="695" y="460" text-anchor="middle" font-size="18" font-weight="700" fill="#333">Protected</text>
    <text x="695" y="486" text-anchor="middle" font-size="18" font-weight="700" fill="#333">Urban Core</text>

    <rect x="604" y="438" width="28" height="28" rx="4" fill="#7bb7db" opacity="0.95"></rect>
    <text x="586" y="468" font-size="14" fill="#444" text-anchor="end">Utility</text>
    <rect x="786" y="486" width="28" height="28" rx="4" fill="#7bb7db" opacity="0.95"></rect>
    <text x="822" y="507" font-size="14" fill="#444">Distributed</text>
    <text x="822" y="525" font-size="14" fill="#444">Cisterns</text>
    <rect x="706" y="564" width="28" height="28" rx="4" fill="#7bb7db" opacity="0.95"></rect>
    <text x="720" y="616" font-size="14" fill="#444" text-anchor="middle">Groundwater</text>
    <text x="720" y="634" font-size="14" fill="#444" text-anchor="middle">Recharge</text>

    <g fill="#3a3a3a" font-size="15" font-weight="600">
      <text x="382" y="544">1. Coastal Buffer</text>
      <text x="382" y="566">(Yellow/Blue)</text>
      <text x="876" y="282">4. Hinterland</text>
      <text x="876" y="304">Catchment</text>
      <text x="876" y="326">(Tan/Brown)</text>
      <text x="900" y="560">2. Peri-Urban</text>
      <text x="900" y="582">Buffer (Green)</text>
      <text x="730" y="370">3. Riparian Buffer</text>
      <text x="730" y="392">(Blue/Teal)</text>
    </g>

    <g fill="#5d5d5d" font-size="14">
      <text x="250" y="656">Nearshore Zone</text>
      <text x="282" y="676">(Sea)</text>
      <text x="1120" y="618">Wildfire</text>
      <text x="1110" y="640">Threat</text>
      <text x="460" y="474">Living</text>
      <text x="452" y="492">Shoreline</text>
      <text x="497" y="606">Elevated</text>
      <text x="498" y="624">Pathways</text>
      <text x="936" y="458">Agricultural</text>
      <text x="946" y="476">Terraces</text>
      <text x="984" y="416">Gravity</text>
      <text x="990" y="434">Water</text>
      <text x="988" y="452">Flow</text>
      <text x="1006" y="334">Reforestation</text>
      <text x="826" y="632">Distributed</text>
      <text x="826" y="650">Infrastructure</text>
      <text x="846" y="668">Network</text>
      <text x="855" y="614">Irrigated</text>
      <text x="844" y="632">Agricultural</text>
      <text x="858" y="650">Park</text>
      <text x="926" y="626">Community</text>
      <text x="942" y="644">Gardens</text>
      <text x="1040" y="574">Fire Pressure</text>
      <text x="1045" y="592">Attenuation</text>
      <text x="320" y="536">Surge</text>
      <text x="308" y="554">Pressure</text>
    </g>

    <path d="M205 575 L318 510" stroke="url(#pf-blue)" stroke-width="18" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M248 630 L358 565" stroke="url(#pf-blue)" stroke-width="18" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M1070 570 L980 530" stroke="url(#pf-orange)" stroke-width="18" marker-end="url(#pf-orange-arrow)"></path>
    <path d="M1080 628 L1004 594" stroke="url(#pf-orange)" stroke-width="18" marker-end="url(#pf-orange-arrow)"></path>
    <path d="M666 560 L596 526" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M704 578 L704 620" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M770 566 L844 598" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M798 456 L878 404" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M792 498 L872 532" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M620 440 L560 372" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>
    <path d="M888 348 L808 316" stroke="url(#pf-blue)" stroke-width="12" marker-end="url(#pf-blue-arrow)"></path>

    <circle cx="388" cy="512" r="28" fill="#f7f5e8" stroke="#d3b859" stroke-width="2"></circle>
    <circle cx="450" cy="458" r="28" fill="#f7f5e8" stroke="#d3b859" stroke-width="2"></circle>
    <circle cx="510" cy="592" r="28" fill="#f7f5e8" stroke="#d3b859" stroke-width="2"></circle>
    <circle cx="960" cy="378" r="28" fill="#eef3e4" stroke="#88a463" stroke-width="2"></circle>
    <circle cx="1008" cy="290" r="28" fill="#f6efdf" stroke="#b49868" stroke-width="2"></circle>
    <circle cx="864" cy="534" r="28" fill="#eef3e4" stroke="#88a463" stroke-width="2"></circle>
    <circle cx="938" cy="608" r="28" fill="#eef3e4" stroke="#88a463" stroke-width="2"></circle>
    <circle cx="860" cy="240" r="28" fill="#f6efdf" stroke="#b49868" stroke-width="2"></circle>
  </svg>
</DiagramFrame>
