---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import NewsBulletin from '../components/NewsBulletin.astro';
import { getCollection } from 'astro:content';

const drawings = await getCollection('drawings');
const maps = await getCollection('maps');
const featured = drawings.slice(0, 3);
---

<BaseLayout title="Home" description="A plan for rebuilding Lahaina after the 2023 wildfire — addressing water, housing, infrastructure, and community resilience.">
  <!-- HERO WITH FLOATING NEWS BULLETIN -->
  <div class="relative">
    <!-- Hero background -->
    <div class="min-h-[75vh] md:min-h-[90vh] flex flex-col justify-end px-6 md:px-16 pb-12 md:pb-16 pt-16 md:pt-20 relative overflow-hidden">
      <!-- Cover image background -->
      <img
        src="/images/drawings/cover_hero.jpg"
        alt="Aerial rendering of proposed Lahaina recovery showing coastal promenade, green infrastructure, and reef"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Gradient overlay for text readability -->
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.85) 55%, #ffffff 100%);"></div>

      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1fr_440px] gap-12 max-w-7xl mx-auto w-full items-end">
        <!-- Left bottom corner: Title and intro -->
        <div>
          <h1 class="font-serif text-[clamp(2.4rem,5vw,4.2rem)] font-normal leading-[1.15] mb-6">
            Rebuilding <em class="text-accent italic">Lahaina</em>
          </h1>
          <p class="text-lg md:text-xl text-text-muted leading-relaxed mb-8 max-w-xl">
            After the 2023 wildfire, Lahaina needs a path forward. This project proposes a recovery plan addressing water systems, housing, infrastructure, and community resilience — built from research, data, and the land itself.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/read/" class="inline-block px-6 py-3 bg-accent text-white text-sm font-medium no-underline rounded hover:opacity-90 transition-opacity">
              Start Reading
            </a>
            <a href="/search" class="inline-block px-6 py-3 border border-border text-text-muted text-sm font-medium no-underline rounded hover:border-accent hover:text-text transition-colors">
              Search the Site
            </a>
          </div>
          <p class="text-sm text-text-muted mt-8">
            A graduate thesis by Akhil Singh — Tulane School of Architecture, M.Arch 2025
          </p>
        </div>

        <!-- Right: Floating news bulletin (bigger) -->
        <div class="lg:-mb-24 relative z-20">
          <NewsBulletin />
        </div>
      </div>
    </div>
  </div>

  <!-- WHAT IS THIS -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-serif text-2xl mb-4">What you'll find here</h2>
    <p class="text-text-muted text-base leading-relaxed mb-10 max-w-2xl">
      This site is a public resource. Everything from the research, maps, and analysis to the recovery plan itself is here for anyone to explore — whether you're a resident, a planner, a researcher, or just someone who cares about Lahaina's future.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <a href="/read/" class="block bg-surface border border-border p-6 no-underline hover:border-accent transition-colors group rounded">
        <h3 class="font-serif text-xl mb-2 text-text group-hover:text-accent transition-colors">Read the Full Thesis</h3>
        <p class="text-text-muted text-sm leading-relaxed">Follow the complete story — from what happened, to what the data shows, to what could be built.</p>
      </a>
      <a href="/topic/" class="block bg-surface border border-border p-6 no-underline hover:border-accent transition-colors group rounded">
        <h3 class="font-serif text-xl mb-2 text-text group-hover:text-accent transition-colors">Browse by Topic</h3>
        <p class="text-text-muted text-sm leading-relaxed">Jump straight to what matters to you — water, housing, fire prevention, cultural heritage, and more.</p>
      </a>
      <a href="/drawing/" class="block bg-surface border border-border p-6 no-underline hover:border-accent transition-colors group rounded">
        <h3 class="font-serif text-xl mb-2 text-text group-hover:text-accent transition-colors">View Maps & Drawings</h3>
        <p class="text-text-muted text-sm leading-relaxed">See the analysis and proposals through detailed maps, plans, sections, and diagrams.</p>
      </a>
    </div>
  </section>

  <!-- ABOUT THE PROJECT -->
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <div class="bg-surface border border-border border-l-[3px] border-l-accent p-6 md:p-8 rounded">
      <h3 class="font-serif text-xl mb-3">About this project</h3>
      <p class="text-text-muted text-base leading-relaxed">
        On August 8, 2023, wind-driven wildfires killed 102 people in Lahaina and destroyed more than 2,200 structures — the deadliest American wildfire in over a century. The proposed framework organizes recovery around three interconnected systems: water-sensitive infrastructure that restores the mauka-to-makai hydrological continuity severed by plantation-era development; a reconfigured mobility network centered on a new inland boulevard replacing the failed coastal evacuation corridor; and a network of community hubs anchoring re-densified housing within walkable, resilient neighborhoods.
      </p>
    </div>
  </section>

  <!-- FEATURED DRAWINGS -->
  {featured.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-16">
      <h2 class="font-serif text-2xl mb-6">Featured Drawings</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {featured.map((d) => (
          <ContentCard
            title={d.data.title}
            href={`/drawing/${d.id}`}
            description={d.data.alt}
            label={d.data.scaleLevel}
            tags={d.data.tags.topic}
          />
        ))}
      </div>
    </section>
  )}

  <!-- INTERACTIVE MAP -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <h2 class="font-serif text-2xl mb-3">Explore the Data</h2>
    <p class="text-text-muted text-base mb-6">Toggle GIS layers to see streams, historic ditches, aquifer boundaries, watersheds, and sea level rise exposure across Lahaina.</p>
    <a href="/map/water-systems-overlay" class="block bg-surface border border-border rounded overflow-hidden no-underline hover:border-accent transition-colors group">
      <div class="p-6">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-serif text-xl text-text group-hover:text-accent transition-colors mb-1">Interactive Map: Water Systems & Hazards</h3>
            <p class="text-sm text-text-muted">5 data layers from Hawaii State GIS, streams, ditches, aquifers, watersheds, and SLR flood exposure</p>
          </div>
          <span class="text-accent text-2xl shrink-0 ml-4">&#8594;</span>
        </div>
      </div>
    </a>
  </section>

  <!-- TIMELINE PREVIEW -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <h2 class="font-serif text-2xl mb-3">Lahaina's Story</h2>
    <p class="text-text-muted text-base mb-6">From the traditional ahupua'a system to the 2023 fire and beyond.</p>
    <a href="/timeline" class="inline-block px-5 py-2.5 border border-border text-sm font-medium no-underline rounded hover:border-accent hover:text-accent transition-colors">
      View Full Timeline
    </a>
  </section>
</BaseLayout>
