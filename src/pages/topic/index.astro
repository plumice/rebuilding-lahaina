---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');
---

<BaseLayout title="Explore by Topic" description="Browse thesis content by thematic topic.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="section-title mb-4">Browse by Topic</h1>
    <p class="text-text-muted text-base leading-relaxed mb-12 max-w-2xl">
      Pick the topic you're interested in. Each one brings together all the related research, maps, drawings, and proposals in one place.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {topics.map((topic) => (
        <ContentCard
          title={topic.data.title}
          href={`/topic/${topic.id}`}
          description={topic.data.summary}
        />
      ))}
    </div>
  </section>
</BaseLayout>
