---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicIcon from '../../components/TopicIcon.astro';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');
---

<BaseLayout title="Explore by Topic" description="Browse thesis content by thematic topic.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="section-title mb-4">Browse by Topic</h1>
    <p class="text-text-muted text-base leading-relaxed mb-12 max-w-2xl">
      Pick the topic you're interested in. Each one brings together all the related research, maps, drawings, and proposals in one place.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {topics.map((topic) => (
        <a href={`/topic/${topic.id}`} class="block bg-surface border border-border rounded p-6 no-underline hover:bg-surface-hover transition-colors group">
          <div class="flex items-start gap-4">
            <div class="text-accent shrink-0 mt-0.5">
              <TopicIcon topic={topic.id} size="lg" />
            </div>
            <div>
              <h2 class="font-serif text-lg text-text group-hover:text-accent transition-colors mb-1">{topic.data.title}</h2>
              <p class="text-sm text-text-muted leading-relaxed">{topic.data.summary}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
