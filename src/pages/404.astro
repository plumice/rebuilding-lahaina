---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="max-w-2xl mx-auto px-6 py-32 text-center">
    <div class="text-accent text-6xl font-serif mb-4">404</div>
    <h1 class="section-title mb-4">Page Not Found</h1>
    <p class="text-text-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>

    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/" class="px-6 py-3 bg-accent text-bg text-sm tracking-widest uppercase no-underline hover:opacity-90 transition-opacity">
        Go Home
      </a>
      <a href="/search" class="px-6 py-3 border border-border text-text-muted text-sm tracking-widest uppercase no-underline hover:text-text hover:border-accent transition-colors">
        Search
      </a>
    </div>

    <div class="mt-12 text-left max-w-sm mx-auto">
      <h2 class="font-serif text-lg mb-4 text-center">Try these instead:</h2>
      <ul class="list-none space-y-3 text-sm">
        <li><a href="/read/" class="text-accent hover:underline">Read the Full Thesis</a></li>
        <li><a href="/topic/" class="text-accent hover:underline">Browse Topics</a></li>
        <li><a href="/drawing/" class="text-accent hover:underline">Maps & Drawings</a></li>
        <li><a href="/timeline" class="text-accent hover:underline">Lahaina's Story</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
