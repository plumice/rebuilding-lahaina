---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all thesis content.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="section-label">Search</div>
    <h1 class="section-title mb-8">Search the Thesis</h1>

    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <div id="search" class="min-h-[400px]"></div>
    <noscript><p class="text-text-muted">Search requires JavaScript.</p></noscript>
  </section>
</BaseLayout>

<script data-cfasync="false" is:inline>
  (function() {
    function loadSearch() {
      var el = document.getElementById('search');
      if (!el) return;
      var script = document.createElement('script');
      script.type = 'module';
      script.textContent = "import {PagefindUI} from '/pagefind/pagefind-ui.js'; new PagefindUI({element:'#search',showSubResults:true,showImages:false});";
      document.body.appendChild(script);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadSearch);
    } else {
      loadSearch();
    }
  })();
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #6d5344;
    --pagefind-ui-text: #1a1a1a;
    --pagefind-ui-background: #f7f7f5;
    --pagefind-ui-border: #e0e0de;
    --pagefind-ui-tag: #eeeeec;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: Inter, -apple-system, sans-serif;
  }

  .pagefind-ui__search-input {
    background: #ffffff !important;
    color: #1a1a1a !important;
  }

  .pagefind-ui__result-link {
    color: #6d5344 !important;
  }

  .pagefind-ui__result-excerpt {
    color: #555555 !important;
  }
</style>
