---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all thesis content.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="section-label">Search</div>
    <h1 class="section-title mb-8">Search the Thesis</h1>

    <div id="search-container" class="min-h-[400px]">
      <div id="search" />
      <noscript><p class="text-text-muted">Search requires JavaScript.</p></noscript>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  window.addEventListener('DOMContentLoaded', async function() {
    try {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);
      var mod = await import('/pagefind/pagefind-ui.js');
      new mod.PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
    } catch (e) {
      var el = document.getElementById('search');
      var msg = document.createElement('p');
      msg.style.color = '#555';
      msg.textContent = 'Search index is loading. If this persists, try refreshing the page.';
      el.appendChild(msg);
    }
  });
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #6d5344;
    --pagefind-ui-text: #1a1a1a;
    --pagefind-ui-background: #f7f7f5;
    --pagefind-ui-border: #e0e0de;
    --pagefind-ui-tag: #eeeeec;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: Inter, -apple-system, sans-serif;
  }

  .pagefind-ui__search-input {
    background: #ffffff !important;
    color: #1a1a1a !important;
  }

  .pagefind-ui__result-link {
    color: #6d5344 !important;
  }

  .pagefind-ui__result-excerpt {
    color: #555555 !important;
  }
</style>
