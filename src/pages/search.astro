---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all thesis content.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="section-label">Search</div>
    <h1 class="section-title mb-8">Search the Thesis</h1>

    <div id="search-container" class="min-h-[400px]">
      <div id="search" />
    </div>
  </section>
</BaseLayout>

<script is:inline>
  async function initSearch() {
    const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
    });
  }
  initSearch();
</script>

<style is:global>
  /* Override Pagefind UI to match light theme */
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #8b7355;
    --pagefind-ui-text: #1a1a1a;
    --pagefind-ui-background: #f7f7f5;
    --pagefind-ui-border: #e0e0de;
    --pagefind-ui-tag: #eeeeec;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: Inter, -apple-system, sans-serif;
  }

  .pagefind-ui__search-input {
    background: #ffffff !important;
    color: #1a1a1a !important;
  }

  .pagefind-ui__result-link {
    color: #8b7355 !important;
  }

  .pagefind-ui__result-excerpt {
    color: #6b6b6b !important;
  }
</style>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
